# Backend environment variables (example; do not commit secrets)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
DATABASE_URL_POOLER="postgresql://USER:PASSWORD@HOST:6543/DBNAME?pgbouncer=true"
EMAIL_USER="you@gmail.com"
EMAIL_PASSWORD="__YOUR_APP_PASSWORD__"
ADMIN_SECRET_KEY="__LONG_RANDOM_STRING__"

# Optional (email behavior)
CONTACT_TO_EMAIL="you@example.com"
CONTACT_FROM_EMAIL="no-reply@example.com"
CONTACT_SEND_USER_CONFIRMATION="true"
CONTACT_RATE_LIMIT_MAX="20"

# Optional (Resend - recommended on hosting where SMTP timeouts happen)
# Uses HTTPS (port 443), generally more reliable than SMTP on PaaS providers.
RESEND_API_KEY=""
RESEND_FROM="no-reply@yourdomain.com"
RESEND_TIMEOUT_MS="10000"

# Optional (SMTP override - defaults are Gmail-friendly: smtp.gmail.com:587)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_CONNECTION_TIMEOUT_MS="15000"
SMTP_GREETING_TIMEOUT_MS="15000"
SMTP_SOCKET_TIMEOUT_MS="20000"
SMTP_LOGGER="false"
SMTP_DEBUG="false"

# Optional (CORS)
# Comma-separated list of allowed origins for browser requests.
# Example: "https://your-prod-domain.tld,https://your-stage-domain.tld"
CORS_ORIGINS=""
# If true, also allows any *.vercel.app origin (useful for previews).
CORS_ALLOW_VERCEL_PREVIEW="false"

# Optional (SMTP TLS)
SMTP_TLS_REJECT_UNAUTHORIZED="true"

# Optional (HSTS)
ENABLE_HSTS="false"
