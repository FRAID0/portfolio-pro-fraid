generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 1. Table des Projets (Optimisée pour l'affichage et l'admin)
model Project {
  id          String   @id @default(uuid())
  title       String
  description String
  category    String   
  tech        String   
  imageUrl    String?  
  githubLink  String?  
  liveLink    String?
  createdAt   DateTime @default(now())

  @@map("projects")
}

// 2. Table des Compétences (Pour la page About dynamique)
model Skill {
  id       String  @id @default(uuid())
  name     String
  category String  
  level    String? 

  @@map("skills")
}

// 3. Table des Messages (Pour ton futur formulaire de contact)
model Message {
  id          String   @id @default(uuid())
  senderName  String
  senderEmail String
  content     String
  isPrivate   Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("messages")
}

// 4. Table des Tags (Pour sélections dynamiques type LinkedIn)
model Tag {
  id    String  @id @default(uuid())
  name  String  @unique
  type  String  

  @@map("tags")
}

// 5. Table des Certificats
model Certificate {
  id        String   @id @default(uuid())
  title     String
  issuer    String
  date      String?  
  link      String?  
  imageUrl  String?
  createdAt DateTime @default(now())

  @@map("certificates")
}

// 6. Table des Expériences
model Experience {
  id          String   @id @default(uuid())
  title       String
  company     String?
  location    String?
  period      String
  description String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

// 7. Profil Admin
model AdminProfile {
  id           String  @id @default(uuid())
  name         String
  photoUrl     String?
  bio          String?
  contactEmail String?
  createdAt    DateTime @default(now())
}