generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 1. Table des Projets (Optimisée pour l'affichage et l'admin)
model Project {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  category    String   // Pour filtrer par IoT, Mobile, Fullstack
  tech        String   // On repasse en String simple pour plus de flexibilité avec ton formulaire actuel
  imageUrl    String?  // Axe 2 : Pour tes captures d'écran
  githubLink  String?  
  liveLink    String?
  createdAt   DateTime @default(now())

  @@map("projects")
}

// 2. Table des Compétences (Pour la page About dynamique)
model Skill {
  id       Int     @id @default(autoincrement())
  name     String
  category String  // ex: "Langages", "Frameworks", "DevOps"
  level    String? // ex: "Avancé", "Intermédiaire"

  @@map("skills")
}

// 3. Table des Messages (Pour ton futur formulaire de contact)
model Message {
  id          Int      @id @default(autoincrement())
  senderName  String
  senderEmail String
  content     String
  isPrivate   Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("messages")
}

// 4. Table des Tags (Pour sélections dynamiques type LinkedIn)
model Tag {
  id    Int     @id @default(autoincrement())
  name  String  @unique
  type  String  // Enum-like string "TECH" ou "CATEGORY"

  @@map("tags")
}

// 5. Table des Certificats
model Certificate {
  id        Int      @id @default(autoincrement())
  title     String
  issuer    String
  date      String?  
  link      String?  
  imageUrl  String?
  createdAt DateTime @default(now())

  @@map("certificates")
}